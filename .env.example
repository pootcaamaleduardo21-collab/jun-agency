# ==========================================
# JUN AGENCY — VARIABLES DE ENTORNO
# ==========================================
# Copia este archivo: cp .env.example .env.local
# Actualiza los valores. NUNCA subas .env.local a Git.

# ── Sitio ──────────────────────────────────
NEXT_PUBLIC_DOMAIN=https://junmkt.com
NEXT_PUBLIC_WHATSAPP=529851089671
NEXT_PUBLIC_EMAIL=informes@junmkt.com

# ── Email (Resend) ──────────────────────────
# Crea una cuenta en https://resend.com (tier gratuito disponible)
# Ve a API Keys > Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CRM Webhook (Opcional) ──────────────────
# Si usas HubSpot, Pipedrive, Zapier o cualquier CRM con webhook:
# Pega aquí la URL del webhook y los formularios enviarán el payload automáticamente
# Formato esperado por el webhook: JSON con todos los campos del formulario
# Deja vacío si no usas CRM todavía
CRM_WEBHOOK_URL=

# ── Analytics (Opcional) ──────────────────
NEXT_PUBLIC_GA_ID=

# ── Vercel (se configura automáticamente en el dashboard) ──
# Agrega RESEND_API_KEY y CRM_WEBHOOK_URL en:
# vercel.com/dashboard → tu-proyecto → Settings → Environment Variables
