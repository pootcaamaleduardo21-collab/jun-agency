# ========================================
# 🚀 JUN AGENCY - VARIABLES DE ENTORNO
# ========================================
# Copia este archivo a .env.local y actualiza los valores

# ========================================
# VARIABLES REQUERIDAS (OBLIGATORIAS)
# ========================================

# Dominio público del sitio (para SEO y links)
# Ejemplo: https://jun.com.mx
NEXT_PUBLIC_DOMAIN=https://jun.com.mx

# Número de WhatsApp sin + ni espacios, con código de país
# Ejemplo México: 529851089671
# Ejemplo España: 34912345678
NEXT_PUBLIC_WHATSAPP=529851089671

# Email público para formulario de contacto
# Usa el mismo email que configures en Formspree
NEXT_PUBLIC_EMAIL=informes@jun.com.mx

# ========================================
# VARIABLES OPCIONALES
# ========================================

# Formspree Form ID (para formulario)
# 1. Ve a https://formspree.io y sign up
# 2. Create new form
# 3. Copia el ID (formato: f_xxxxxxxx)
NEXT_PUBLIC_FORMSPREE_ID=f_xxxxxxxx

# Google Analytics Measurement ID
# 1. Ve a https://analytics.google.com
# 2. Create property
# 3. Copia el Measurement ID (formato: G-XXXXXXXXXX)
# Deja vacío si no usas Analytics
NEXT_PUBLIC_GA_ID=

# ========================================
# 📋 INSTRUCCIONES IMPORTANTES
# ========================================

# 1. DESARROLLO LOCAL:
#    - Copia este archivo: cp .env.example .env.local
#    - Actualiza los valores
#    - .env.local está en .gitignore (nunca se sube a Git)
#    - Reinicia servidor después de cambios: Ctrl+C → npm run dev

# 2. VERCEL PRODUCTION:
#    - Ve a: vercel.com/dashboard → tu-proyecto → Settings
#    - Sección: Environment Variables
#    - Agrega las mismas variables
#    - Automáticamente disponibles en producción

# 3. SEGURIDAD:
#    - NUNCA compartas .env.local
#    - NUNCA guardes tokens o secrets en variables NEXT_PUBLIC_*
#    - Variables NEXT_PUBLIC_* son visibles al cliente
#    - Solo usa para datos públicos (emails, números, dominios)

# 4. CAMBIOS EN VARIABLES:
#    - Cambios en .env.local requieren reiniciar servidor local
#    - En Vercel, los cambios se aplican en el siguiente deploy
#    - Para deploy inmediato: git push (trigger GitHub Actions)

# ========================================
